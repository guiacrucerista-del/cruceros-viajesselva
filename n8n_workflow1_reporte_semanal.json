            {
              "name": "endDate",
              "value": "={{ $now.minus({weeks: 1}).endOf('week').toFormat('yyyy-MM-dd') }}"
            },
            {
              "name": "dimensions",
              "value": "[\"query\",\"page\"]"
            },
            {
              "name": "rowLimit",
              "value": "25"
            }
          ]
        }
      },
      "id": "gsc-fetch",
