          { "name": "access_token", "value": "EAAUOpOCfmP8BRe9zrGZAxsugMjZC49Kj7V37gpNTda7UV92SbWrLusaEZCDnvYUIHL2NzZAGdCaxlHkk3ZBKdIuij5yDvn5JH6f21AgQtZC8b1jLy94FRUqVAvGkCLADlDTnXtK4NmAkwKOE8TZAa5eFZCw25A2gGk5Gb1uOiTJsh0yWbpvsXXSIcxl2DY4Gy9MhkZAaOM80vxWEazSZA7AvFOi1BrNkUvis0dV9Flt6nv4tCJtlBQSdb3vxQR3XtpnkVWXZAowBzjgLJxmHIiqRms2tJ9ZAUwZDZD" }
        ]}
      },
      "id": "comentar-pagina",
      "name": "Comentar URL Pagina",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1340, 260]
    },
    {
      "parameters": {
        "jsCode": "const p = $('Preparar Post').item.json;\nconst data = {\n  text:   p.texto,\n  url:    p.urlMSC,\n  groups: ['811550587597467','1116074769675601','1882092085657041']\n};\nconst fs = require('fs');\nfs.writeFileSync('/tmp/fb_post.json', JSON.stringify(data));\nreturn [{ json: { inputFile: '/tmp/fb_post.json', texto: p.texto } }];"
      },
      "id": "write-post-file",
      "name": "Escribir Archivo Post",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 540]
    },
    {
      "parameters": {
        "command": "cd /opt/guiacrucerista/scripts && source .env && node playwright_facebook_grupos.js --input /tmp/fb_post.json"
      },
      "id": "playwright-grupos",
      "name": "Playwright — Publicar en Grupos",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [1340, 540]
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.item.json.stdout || '{}';\ntry {\n  const r = JSON.parse(raw);\n  return [{ json: { playwrightOK: r.success, grupos: r.groups } }];\n} catch(e) {\n  return [{ json: { playwrightOK: false, error: e.message } }];\n}"
      },
      "id": "parse-playwright",
      "name": "Parsear Resultado Playwright",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1560, 540]
    },
