    {
      "parameters": {
        "jsCode": "const item = $input.item.json;\nconst texto = item['Texto'] || '';\nconst naviera = item['Naviera'] || 'General';\nconst destino = item['Destino'] || '';\nconst publicarPagina = (item['Publicar Pagina'] || 'SI').toUpperCase() === 'SI';\nconst publicarMSC = (item['Grupo MSC'] || 'SI').toUpperCase() === 'SI';\nconst publicarRCL = (item['Grupo Royal'] || 'SI').toUpperCase() === 'SI';\nconst publicarCosta = (item['Grupo Costa'] || 'SI').toUpperCase() === 'SI';\nconst slug = `${naviera}-${destino}`.toLowerCase().replace(/\\s+/g, '-').replace(/[^a-z0-9-]/g, '');\nconst fechaHoy = new Date().toISOString().split('T')[0];\nconst utm = `utm_medium=social&utm_campaign=${slug}&utm_content=${fechaHoy}`;\nreturn [{ json: {\n  texto,\n  naviera,\n  destino,\n  publicarPagina,\n  publicarMSC,\n  publicarRCL,\n  publicarCosta,\n  urlPagina: `https://guiacrucerista.com?utm_source=fb-pagina&${utm}`,\n  urlMSC: `https://guiacrucerista.com?utm_source=fb-grupo-msc&${utm}`,\n  urlRoyal: `https://guiacrucerista.com?utm_source=fb-grupo-royal&${utm}`,\n  urlCosta: `https://guiacrucerista.com?utm_source=fb-grupo-costa&${utm}`,\n  fechaHoy,\n  rowNumber: item['_rowNumber'] || 2\n}}];"
      },
      "id": "preparar-post",
      "name": "Preparar Post",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 400]
    },
    {
      "parameters": {
        "conditions": { "boolean": [{ "value1": "={{ $json.publicarPagina }}", "value2": true }] }
      },
