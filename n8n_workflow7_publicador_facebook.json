    {
      "parameters": {
        "command": "curl -fsSL -o /opt/guiacrucerista/scripts/playwright_facebook_grupos.js https://raw.githubusercontent.com/guiacrucerista-del/cruceros-viajesselva/main/playwright_facebook_grupos.js && echo OK"
      },
      "id": "auto-update",
      "name": "Auto-Update Script Playwright",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [240, 400]
    },
    {
      "parameters": {
        "operation": "getAll",
        "documentId": { "__rl": true, "value": "14QcT_BFRUGjP5Z69sdoAPYfNtRlrJ1u2cDsmIP4CVWk", "mode": "id" },
        "sheetName": { "__rl": true, "value": "Cola de Publicaciones", "mode": "name" },
        "filters": { "conditions": [{ "keyName": "Estado", "condition": "equals", "keyValue": "Pendiente" }] },
        "options": { "returnAllMatches": true }
      },
      "id": "sheets-cola",
      "name": "Sheets - Leer Cola",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [460, 400]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.item.json;\nconst naviera = item['Naviera'] || 'General';\nconst destino = item['Destino'] || '';\nconst slug = (naviera + '-' + destino).toLowerCase().replace(/\\s+/g, '-').replace(/[^a-z0-9-]/g, '');\nconst fechaHoy = new Date().toISOString().split('T')[0];\nconst utm = 'utm_medium=social&utm_campaign=' + slug + '&utm_content=' + fechaHoy;\nreturn [{ json: {\n  texto: item['Texto'] || '',\n  naviera,\n  destino,\n  publicarPagina: (item['Publicar Pagina'] || 'SI').toUpperCase() === 'SI',\n  urlPagina:  'https://guiacrucerista.com?utm_source=fb-pagina&' + utm,\n  urlMSC:     'https://guiacrucerista.com?utm_source=fb-grupo-msc&' + utm,\n  urlRoyal:   'https://guiacrucerista.com?utm_source=fb-grupo-royal&' + utm,\n  urlCosta:   'https://guiacrucerista.com?utm_source=fb-grupo-costa&' + utm,\n  fechaHoy,\n  rowNumber: item['_rowNumber'] || 2\n}}];"
      },
      "id": "preparar-post",
      "name": "Preparar Post",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 400]
    },
    {
      "parameters": {
        "conditions": { "boolean": [{ "value1": "={{ $json.publicarPagina }}", "value2": true }] }
      },
      "id": "if-pagina",
      "name": "IF Pagina",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [900, 400]
    },
    {
      "parameters": {
        "url": "https://graph.facebook.com/v20.0/360998217104895/feed",
        "method": "POST",
        "sendBody": true,
        "bodyParameters": { "parameters": [
          { "name": "message",      "value": "={{ $('Preparar Post').item.json.texto }}" },
          { "name": "access_token", "value": "EAAUOpOCfmP8BRe9zrGZAxsugMjZC49Kj7V37gpNTda7UV92SbWrLusaEZCDnvYUIHL2NzZAGdCaxlHkk3ZBKdIuij5yDvn5JH6f21AgQtZC8b1jLy94FRUqVAvGkCLADlDTnXtK4NmAkwKOE8TZAa5eFZCw25A2gGk5Gb1uOiTJsh0yWbpvsXXSIcxl2DY4Gy9MhkZAaOM80vxWEazSZA7AvFOi1BrNkUvis0dV9Flt6nv4tCJtlBQSdb3vxQR3XtpnkVWXZAowBzjgLJxmHIiqRms2tJ9ZAUwZDZD" }
        ]}
