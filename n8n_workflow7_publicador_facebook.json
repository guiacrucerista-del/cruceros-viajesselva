    {
      "parameters": {
        "jsCode": "const raw = $input.item.json.stdout || '{}';
try {
  const result = JSON.parse(raw);
  return [{ json: { playwrightResult: result, success: result.success } }];
} catch (e) {
  return [{ json: { playwrightResult: null, success: false, parseError: e.message } }];
}"
